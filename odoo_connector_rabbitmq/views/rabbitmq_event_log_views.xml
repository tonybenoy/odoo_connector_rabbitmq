<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- List View -->
    <record id="rabbitmq_event_log_view_tree" model="ir.ui.view">
        <field name="name">rabbitmq.event.log.tree</field>
        <field name="model">rabbitmq.event.log</field>
        <field name="arch" type="xml">
            <tree decoration-success="state in ('sent', 'received')"
                  decoration-danger="state in ('failed', 'dead')"
                  decoration-warning="state == 'pending'"
                  default_order="create_date desc">
                <field name="create_date" string="Date"/>
                <field name="direction" widget="badge"
                       decoration-info="direction == 'outbound'"
                       decoration-success="direction == 'inbound'"/>
                <field name="model_name" string="Model"/>
                <field name="event_type" string="Event"/>
                <field name="state" widget="badge"
                       decoration-success="state in ('sent', 'received')"
                       decoration-danger="state in ('failed', 'dead')"
                       decoration-warning="state == 'pending'"/>
                <field name="routing_key"/>
                <field name="retry_count" string="Retries" optional="show"/>
                <field name="event_id" optional="hide"/>
                <field name="exchange_name" optional="hide"/>
                <field name="next_retry_at" optional="hide"/>
                <field name="error_message" string="Error" optional="hide"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="rabbitmq_event_log_view_form" model="ir.ui.view">
        <field name="name">rabbitmq.event.log.form</field>
        <field name="model">rabbitmq.event.log</field>
        <field name="arch" type="xml">
            <form create="false">
                <header>
                    <button name="action_retry" string="Retry" type="object"
                            class="oe_highlight"
                            invisible="state not in ('failed', 'dead')"
                            groups="odoo_connector_rabbitmq.group_rabbitmq_manager"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="pending,sent,received,failed,dead"/>
                </header>
                <sheet>
                    <group>
                        <group string="Event">
                            <field name="event_id" string="ID"/>
                            <field name="direction"/>
                            <field name="model_name" string="Model"/>
                            <field name="event_type" string="Event"/>
                            <field name="record_ids"/>
                            <field name="create_date" string="Created"/>
                        </group>
                        <group string="Routing">
                            <field name="exchange_name"/>
                            <field name="routing_key"/>
                            <field name="queue_name"/>
                        </group>
                    </group>
                    <group string="Error Details"
                           invisible="state not in ('failed', 'dead')">
                        <group>
                            <field name="retry_count"/>
                            <field name="max_retries"/>
                            <field name="next_retry_at"/>
                        </group>
                        <group>
                            <field name="error_message" nolabel="True"
                                   colspan="2"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Payload" name="payload">
                            <field name="payload" widget="code" nolabel="True"
                                   readonly="True"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="rabbitmq_event_log_view_search" model="ir.ui.view">
        <field name="name">rabbitmq.event.log.search</field>
        <field name="model">rabbitmq.event.log</field>
        <field name="arch" type="xml">
            <search>
                <field name="event_id"/>
                <field name="model_name" string="Model"/>
                <field name="event_type"/>
                <field name="exchange_name"/>
                <field name="routing_key"/>
                <separator/>
                <filter name="filter_pending" string="Pending"
                        domain="[('state', '=', 'pending')]"/>
                <filter name="filter_sent" string="Sent"
                        domain="[('state', '=', 'sent')]"/>
                <filter name="filter_received" string="Received"
                        domain="[('state', '=', 'received')]"/>
                <filter name="filter_failed" string="Failed"
                        domain="[('state', '=', 'failed')]"/>
                <filter name="filter_dead" string="Dead"
                        domain="[('state', '=', 'dead')]"/>
                <separator/>
                <filter name="filter_outbound" string="Outbound"
                        domain="[('direction', '=', 'outbound')]"/>
                <filter name="filter_inbound" string="Inbound"
                        domain="[('direction', '=', 'inbound')]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter name="group_state" string="State"
                            context="{'group_by': 'state'}"/>
                    <filter name="group_direction" string="Direction"
                            context="{'group_by': 'direction'}"/>
                    <filter name="group_model" string="Model"
                            context="{'group_by': 'model_name'}"/>
                    <filter name="group_event_type" string="Event Type"
                            context="{'group_by': 'event_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="rabbitmq_event_log_action" model="ir.actions.act_window">
        <field name="name">Event Log</field>
        <field name="res_model">rabbitmq.event.log</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No events yet
            </p>
            <p>
                Events appear here when your Event Rules capture model operations
                or when Consumer Rules process inbound messages.
            </p>
        </field>
    </record>

    <!-- Dashboard List View (with Retry All Dead button) -->
    <record id="rabbitmq_event_log_dashboard_tree" model="ir.ui.view">
        <field name="name">rabbitmq.event.log.dashboard.tree</field>
        <field name="model">rabbitmq.event.log</field>
        <field name="arch" type="xml">
            <tree decoration-success="state in ('sent', 'received')"
                  decoration-danger="state in ('failed', 'dead')"
                  decoration-warning="state == 'pending'"
                  default_order="create_date desc">
                <header>
                    <button name="action_retry_all_dead"
                            string="Retry All Dead"
                            type="object"
                            class="btn-secondary"
                            groups="odoo_connector_rabbitmq.group_rabbitmq_manager"/>
                </header>
                <field name="create_date" string="Date"/>
                <field name="direction" widget="badge"
                       decoration-info="direction == 'outbound'"
                       decoration-success="direction == 'inbound'"/>
                <field name="model_name" string="Model"/>
                <field name="event_type" string="Event"/>
                <field name="state" widget="badge"
                       decoration-success="state in ('sent', 'received')"
                       decoration-danger="state in ('failed', 'dead')"
                       decoration-warning="state == 'pending'"/>
                <field name="routing_key"/>
                <field name="retry_count" string="Retries" optional="show"/>
                <field name="error_message" string="Error" optional="hide"/>
            </tree>
        </field>
    </record>

    <!-- Dashboard Action -->
    <record id="rabbitmq_event_log_dashboard_action" model="ir.actions.act_window">
        <field name="name">Dashboard</field>
        <field name="res_model">rabbitmq.event.log</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="rabbitmq_event_log_dashboard_tree"/>
        <field name="context">{'search_default_group_state': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Your RabbitMQ dashboard is empty
            </p>
            <p>
                Start by creating a <strong>Connection</strong>, then set up
                <strong>Event Rules</strong> to capture model changes.
            </p>
        </field>
    </record>

</odoo>
