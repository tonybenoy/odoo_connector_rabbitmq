<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.rabbitmq</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="RabbitMQ" string="RabbitMQ"
                     data-key="odoo_connector_rabbitmq">

                    <block title="Connection">
                        <setting string="Default Connection"
                                 help="All publishing and consuming uses this connection. Set up connections under Configuration > Connections.">
                            <field name="rabbitmq_connection_id"/>
                        </setting>
                    </block>

                    <block title="Publishing">
                        <setting string="Enable Publishing"
                                 help="Publish outbound events to RabbitMQ via the scheduled cron job. When disabled, events still accumulate in the outbox but are not sent.">
                            <field name="rabbitmq_publish_enabled"/>
                        </setting>
                        <setting string="Enable Global Hook"
                                 help="Automatically capture create/update/delete operations on models with Event Rules. When disabled, no new events are logged regardless of configured rules.">
                            <field name="rabbitmq_global_hook_enabled"/>
                        </setting>
                    </block>

                    <block title="Consuming">
                        <setting string="Enable Consuming"
                                 help="Process inbound messages from RabbitMQ queues using Consumer Rules.">
                            <field name="rabbitmq_consume_enabled"/>
                        </setting>
                        <setting string="Consumer Interval (minutes)"
                                 help="How often the consumer cron job runs. Lower values mean faster message processing but more load.">
                            <field name="rabbitmq_consumer_interval"/>
                        </setting>
                    </block>

                    <block title="Safety">
                        <setting string="Allow Delete via Field Mapping"
                                 help="When enabled, consumer rules in Field Mapping mode can delete records. Keep disabled to prevent accidental data loss from inbound messages.">
                            <field name="rabbitmq_consumer_allow_delete"/>
                        </setting>
                        <setting string="Max Retries"
                                 help="How many times a failed event is retried before being marked as dead. Uses exponential backoff (2, 4, 8, 16, 32 minutes).">
                            <field name="rabbitmq_max_retries"/>
                        </setting>
                        <setting string="Log Retention (days)"
                                 help="Sent and received event logs older than this are automatically cleaned up.">
                            <field name="rabbitmq_log_retention_days"/>
                        </setting>
                    </block>

                    <block title="Connection Tuning">
                        <setting string="Blocked Connection Timeout (seconds)"
                                 help="How long to wait when RabbitMQ blocks the connection (e.g. memory alarm). 0 = wait forever.">
                            <field name="rabbitmq_blocked_connection_timeout"/>
                        </setting>
                        <setting string="Connection Attempts"
                                 help="Number of times to retry connecting before giving up.">
                            <field name="rabbitmq_connection_attempts"/>
                        </setting>
                        <setting string="Retry Delay (seconds)"
                                 help="Wait time between connection retry attempts.">
                            <field name="rabbitmq_retry_delay"/>
                        </setting>
                    </block>

                </app>
            </xpath>
        </field>
    </record>

</odoo>
