<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">

        <!-- Module category for grouping in Settings > Users -->
        <record id="module_category_rabbitmq" model="ir.module.category">
            <field name="name">RabbitMQ</field>
            <field name="sequence">100</field>
        </record>

        <!-- Privilege links category to groups (Odoo 19+) -->
        <record id="privilege_rabbitmq" model="res.groups.privilege">
            <field name="name">RabbitMQ</field>
            <field name="category_id" ref="module_category_rabbitmq"/>
        </record>

        <record id="group_rabbitmq_user" model="res.groups">
            <field name="name">RabbitMQ User</field>
            <field name="privilege_id" ref="privilege_rabbitmq"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_rabbitmq_manager" model="res.groups">
            <field name="name">RabbitMQ Manager</field>
            <field name="privilege_id" ref="privilege_rabbitmq"/>
            <field name="implied_ids" eval="[(4, ref('group_rabbitmq_user'))]"/>
            <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>

    </data>
</odoo>
