<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">

        <!-- Default localhost connection -->
        <record id="rabbitmq_connection_default" model="rabbitmq.connection">
            <field name="name">Default (localhost)</field>
            <field name="host">localhost</field>
            <field name="port">5672</field>
            <field name="username">guest</field>
            <field name="password">guest</field>
            <field name="virtual_host">/</field>
        </record>

        <!-- Set as default connection -->
        <record id="default_connection_param" model="ir.config_parameter">
            <field name="key">odoo_connector_rabbitmq.default_connection_id</field>
            <field name="value" ref="rabbitmq_connection_default"/>
        </record>

    </data>
</odoo>
