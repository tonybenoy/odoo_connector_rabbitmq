<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">

        <!-- Cron: Process Outbound Events -->
        <record id="rabbitmq_cron_process_outbound" model="ir.cron">
            <field name="name">RabbitMQ: Process Outbound Events</field>
            <field name="model_id" ref="model_rabbitmq_event_log"/>
            <field name="state">code</field>
            <field name="code">model._process_pending_outbound()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">minutes</field>

            <field name="active">True</field>
            <field name="priority">5</field>
        </record>

        <!-- Cron: Process Inbound + Retry Failed -->
        <record id="rabbitmq_cron_process_inbound" model="ir.cron">
            <field name="name">RabbitMQ: Process Inbound + Retry Failed</field>
            <field name="model_id" ref="model_rabbitmq_event_log"/>
            <field name="state">code</field>
            <field name="code">model._process_inbound()
model._retry_failed_events()</field>
            <field name="interval_number">2</field>
            <field name="interval_type">minutes</field>

            <field name="active">True</field>
            <field name="priority">5</field>
        </record>

        <!-- Cron: Cleanup Old Logs -->
        <record id="rabbitmq_cron_cleanup_logs" model="ir.cron">
            <field name="name">RabbitMQ: Cleanup Old Event Logs</field>
            <field name="model_id" ref="model_rabbitmq_event_log"/>
            <field name="state">code</field>
            <field name="code">model._cleanup_old_logs()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>

            <field name="active">True</field>
            <field name="priority">10</field>
        </record>

    </data>
</odoo>
